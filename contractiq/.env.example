# =====================================================================
# ContractIQ — Environment Variables (TEMPLATE — no real secrets here)
# Copy this file to `.env.local` (same folder) and put real values there.
#   cp .env.example .env.local
# NEXT_PUBLIC_* are exposed to the browser. Everything else is SERVER ONLY.
# `.env.local` is gitignored. Keep real keys OUT of this template file.
# =====================================================================

# --- Supabase ---------------------------------------------------------
# From your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=            # Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # anon / public key (safe in the browser)
SUPABASE_SERVICE_ROLE_KEY=           # service_role key — SERVER ONLY (bypasses RLS; never ship to client)

# Storage bucket that holds uploaded PDFs (created by docs/specs/supabase-schema.sql)
SUPABASE_STORAGE_BUCKET=contracts

# --- OpenAI -----------------------------------------------------------
# From https://platform.openai.com/api-keys
# NOTE: the lab README calls this OPEN_API_KEY — that is a typo. The correct
# variable name used throughout this app is OPENAI_API_KEY.
OPENAI_API_KEY=                      # SERVER ONLY — never expose to the client
OPENAI_MODEL=gpt-4o                  # extraction + chat model (see engineering-doc §8)

# --- Application ------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000   # base URL used for redirects/links

# --- Limits (server-enforced; see engineering-doc §5, §8.6) -----------
MAX_UPLOAD_MB=10                     # reject PDFs larger than this
MAX_PAGES=20                         # reject PDFs with more pages than this
MAX_CONTRACT_TOKENS=15000            # reject contracts longer than this
MAX_CUSTOM_TERMS=5                   # max user-defined terms per analysis
SIGNED_URL_TTL_SECONDS=3600          # PDF viewer signed-URL expiry (1 hour)
